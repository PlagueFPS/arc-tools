{
  "name": "arc-tools",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:twitch": "turbo run dev --filter=twitch-bot",
    "dev:discord": "turbo run dev --filter=discord-bot",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run format-and-lint",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@effect/language-service": "0.73.1",
    "turbo": "2.8.7",
    "typescript": "5.9.3"
  }
}
