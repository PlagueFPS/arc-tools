{
  "name": "arc-tools",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "dev:twitch": "turbo run dev --filter=twitch-bot",
    "dev:discord": "turbo run dev --filter=discord-bot",
    "lint": "turbo run format-and-lint",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@effect/language-service": "^0.77.0",
    "@effect/vitest": "4.0.0-beta.27",
    "turbo": "^2.8.13",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
